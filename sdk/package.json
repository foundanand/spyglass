{
  "name": "@spyglass/sdk",
  "version": "0.0.0",
  "description": "Tiny telemetry SDK for spyglass: events, replay, errors, and bug reports.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@rrweb/rrweb-plugin-console-record": "^2.0.1",
    "rrweb": "^2.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
